# The agent reads these at runtime (export them, or set in your shell profile).
LOCALLMOS_SUPABASE_URL=http://localhost:54321
LOCALLMOS_SUPABASE_ANON_KEY=your-anon-key

# Which local engine the agent drives: "ollama" (default) or "llamacpp"
# (llama-server, native grammar-constrained tool calling). The installer sets
# this for you when run with `--runtime llamacpp`.
# LOCALLMOS_RUNTIME=ollama

# --- Ollama runtime (LOCALLMOS_RUNTIME=ollama) ------------------------------
# LOCALLMOS_OLLAMA_URL=http://127.0.0.1:11434
# How long Ollama keeps a model resident between chat turns (overrides the
# server's OLLAMA_KEEP_ALIVE). Use "-1" to keep it loaded indefinitely.
# LOCALLMOS_CHAT_KEEP_ALIVE=30m

# --- llama.cpp runtime (LOCALLMOS_RUNTIME=llamacpp) -------------------------
# Path to the llama-server binary the agent launches (provisioned by the
# installer), and the directory it serves *.gguf models from.
# LOCALLMOS_LLAMACPP_BIN=/opt/locallmos/llama/llama-b10068/llama-server
# LOCALLMOS_LLAMACPP_MODELS_DIR=/var/lib/locallmos/models
# LOCALLMOS_LLAMACPP_PORT=8080
# LOCALLMOS_LLAMACPP_NGL=999        # GPU layers to offload (999 = all)
# LOCALLMOS_LLAMACPP_CTX=8192       # context window
# LOCALLMOS_LLAMACPP_THINKING=1     # set if the model reasons (enables thinking)
# LOCALLMOS_LLAMACPP_ARGS=          # extra flags passed through to llama-server
# Auto-selects discrete GPU(s) of any vendor over a weak CPU iGPU when both are
# present (keeps mixed NVIDIA+AMD discrete builds using both; leaves single-GPU /
# unified-memory boxes — Apple, Strix Halo, DGX Spark — and homogeneous multi-GPU
# rigs untouched). Set to 0 to disable, or pass your own --device in
# LOCALLMOS_LLAMACPP_ARGS to override.
# LOCALLMOS_LLAMACPP_AUTODEVICE=1

# LOCALLMOS_TELEMETRY_SECS=10
# LOCALLMOS_COMMAND_POLL_SECS=3
# LOCALLMOS_RECONCILE_SECS=20
