# Installed to /etc/locallmos-agent/agent.env and read by the systemd service.
LOCALLMOS_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
LOCALLMOS_SUPABASE_ANON_KEY=your-anon-key

# Optional overrides
# LOCALLMOS_OLLAMA_URL=http://127.0.0.1:11434
# LOCALLMOS_TELEMETRY_SECS=10
# LOCALLMOS_COMMAND_POLL_SECS=3
# LOCALLMOS_RECONCILE_SECS=20
# RUST_LOG=info

# llama.cpp runtime (set by the installer when --runtime llamacpp is used).
# LOCALLMOS_RUNTIME=llamacpp
# LOCALLMOS_LLAMACPP_BACKEND=auto        # auto|cuda|rocm|vulkan|cpu|metal (forced = no fallback)
# LOCALLMOS_LLAMACPP_VERSION=b10068      # pinned llama.cpp release tag, or "latest"
# LOCALLMOS_LLAMACPP_CUDA_REPO=jcam7044/locallmos-agent  # source of self-hosted Linux CUDA prebuilts
# LOCALLMOS_LLAMACPP_BIN=/opt/locallmos/llama/.../llama-server
# LOCALLMOS_LLAMACPP_MODELS_DIR=/var/lib/locallmos/models
