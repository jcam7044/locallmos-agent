{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocaLLMOS Agent",
  "identifier": "os.locallmos.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "LocaLLMOS Agent",
        "width": 480,
        "height": 560,
        "minWidth": 420,
        "minHeight": 480,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
